{
  "github": {
    "silent": true,
    "autoJobCancelation": true
  },
  "ignoreCommand": "git diff --quiet HEAD~1 HEAD -- apps/website/",
  "rewrites": [
    {
      "source": "/api/connect",
      "destination": "https://infinitecode-admin.vercel.app/api/connect"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
