# Supabase auth — same project as InfiniteCodeBackend admin panel
# 1. Copy: `cp .env.example .env`
# 2. Get values from your Supabase dashboard:
#    Project Settings → API → Project URL + anon public key
# 3. Restart `bun run dev` so Vite picks them up.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Optional: used only by /api/connect SSR endpoints if you host them on
# Vercel. Leave unset on pure SPA builds — the browser client works
# using the public anon key alone.
SUPABASE_SERVICE_ROLE_KEY=
